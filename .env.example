# 이 파일을 .env 로 복사해 실제 키를 채우세요. (.env 는 git 제외)

# Kakao Local + 카카오 로그인 — developers.kakao.com의 REST API 키
KAKAO_API_KEY=YOUR_KAKAO_REST_API_KEY
# 카카오 콘솔 [보안]에서 Client Secret 활성화한 경우에만 입력
KAKAO_CLIENT_SECRET=

# ODsay 대중교통 (lab.odsay.com, 일 1,000건 쿼터)
ODSAY_API_KEY=YOUR_ODSAY_API_KEY

# Naver DataLab/Blog + 네이버 로그인 (developers.naver.com)
NAVER_CLIENT_ID=YOUR_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=YOUR_NAVER_CLIENT_SECRET

# 공공데이터포털 (data.go.kr) — TourAPI·열차정보 동일 계정 키
# 디코딩(Decoding) 키 사용 (== 로 끝나는 것). 코드가 알아서 URL 인코딩함.
TOUR_API_KEY=YOUR_DATA_GO_KR_DECODING_KEY
DATAGO_API_KEY=YOUR_DATA_GO_KR_DECODING_KEY

# OpenAI — Spring AI 챗봇 + ai-server 임베딩/LLM
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# JWT 서명 키 — openssl rand -base64 48 로 생성
JWT_SECRET=YOUR_RANDOM_SECRET_48B

# --- 프론트는 frontend/.env.local 에 별도 작성 ---
# VITE_KAKAO_MAP_KEY=카카오 JavaScript 키 (REST 키와 다름)
# VITE_KAKAO_CLIENT_ID=카카오 REST API 키
# VITE_NAVER_CLIENT_ID=네이버 Client ID
